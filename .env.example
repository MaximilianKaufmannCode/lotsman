# Лоцман — environment variable reference
# Copy this file to .env and fill in real values before running `make dev`.
# .env is gitignored. Never commit actual secrets.
#
# For production: use Docker secrets or a secrets manager (pass, Vault, etc.)
# for any PASSWORD / KEY / TOKEN / SECRET variable.

# ── General ───────────────────────────────────────────────────────────────────

# Deployment environment tag. Controls logging verbosity and debug flags.
# Values: dev | staging | production
LOTSMAN_ENV=dev

# Application version tag, used in compose.prod.yml image references.
# Example: 1.2.3
LOTSMAN_VERSION=0.1.0

# Root log level for all Python services (Python logging / structlog).
# Values: debug | info | warning | error | critical
LOG_LEVEL=info

# ── PostgreSQL ─────────────────────────────────────────────────────────────────

# Postgres superuser password (used by the postgres container itself).
# The application services do NOT use this password; they use per-service roles.
POSTGRES_PASSWORD=changeme

# Postgres host as seen from within the compose network
POSTGRES_HOST=postgres

# Postgres port (default 5432; exposed on 127.0.0.1 in dev)
POSTGRES_PORT=5432

# Database name (single database, four schemas)
POSTGRES_DB=lotsman

# ── Per-service database URLs ─────────────────────────────────────────────────
# Each URL uses the service-scoped Postgres role created by 01-schemas-and-roles.sql.
# The role names (auth_app, registry_app, etc.) are fixed by that SQL file.
# Passwords for these roles must be set by the operator and injected at runtime.
# In dev: set the role passwords once via psql after container init:
#   docker exec -it lotsman_postgres psql -U postgres -c "ALTER ROLE auth_app PASSWORD 'changeme_auth';"
# In production: use Docker secrets or pass; never put real passwords here.

# auth-service database URL (async driver for SQLAlchemy 2)
AUTH_DATABASE_URL=postgresql+asyncpg://auth_app:changeme_auth@postgres:5432/lotsman

# Password for the auth_app role (used in AUTH_DATABASE_URL above)
AUTH_PG_PASSWORD=changeme_auth

# registry-service database URL
REGISTRY_DATABASE_URL=postgresql+asyncpg://registry_app:changeme_registry@postgres:5432/lotsman

# Password for the registry_app role
REGISTRY_PG_PASSWORD=changeme_registry

# notification-service database URL
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://notification_app:changeme_notification@postgres:5432/lotsman

# Password for the notification_app role
NOTIFICATION_PG_PASSWORD=changeme_notification

# audit-service database URL
AUDIT_DATABASE_URL=postgresql+asyncpg://audit_app:changeme_audit@postgres:5432/lotsman

# Password for the audit_app role
AUDIT_PG_PASSWORD=changeme_audit

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis connection URL (used by all services for sessions, queues, rate limiters)
REDIS_URL=redis://redis:6379/0

# ── JWT — External (user-facing) ─────────────────────────────────────────────
# RS256 keypair: auth-service signs, all services verify.
# Generate in infra/secrets-dev/ — see infra/secrets-dev/README.md for commands.
# In production: mount via Docker secrets or a secrets manager.

# Path to the RS256 private key PEM file (inside the auth-service container)
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key

# Path to the RS256 public key PEM file (inside all service containers)
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key

# web-bff fail-closed JWT verification (security remediation 2026-06).
# Keep false (default): a missing/misconfigured key then fails web-bff startup
# instead of silently accepting UNVERIFIED tokens. Set true ONLY for local dev
# that runs without the RS256 key.
JWT_ALLOW_UNVERIFIED=false

# ── JWT — Internal (service-to-service, per ADR-0002 §E) ─────────────────────
# HS256 shared secret: web-bff signs, backend services verify.
# TTL is 60 seconds. Rotate every 90 days.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_JWT_SECRET=changeme_internal_jwt_secret_replace_with_random_hex

# ── TOTP ─────────────────────────────────────────────────────────────────────
# Fernet key used to encrypt TOTP secrets at rest in the database.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# See infra/secrets-dev/README.md for the full command.
TOTP_ENC_KEY=changeme_fernet_key_replace_with_generated_value

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# In dev: points to Mailpit (SMTP on port 1025, web UI on http://localhost:8025)
# In production: replace with your corporate SMTP relay credentials.
SMTP_HOST=mailpit
SMTP_PORT=1025

# Sender address shown in all email notifications from Лоцман
SMTP_FROM=Лоцман <noreply@lotsman.example.com>

# SMTP authentication (leave empty for Mailpit dev relay)
SMTP_USER=
SMTP_PASSWORD=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Telegram Bot API token (create bot via @BotFather).
# Leave empty to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=

# ── Dion ──────────────────────────────────────────────────────────────────────
# Dion corporate messenger API (https://faq.dion.vc/ru/deployment-settings/api)
# Leave empty to disable Dion notifications.
DION_API_BASE=https://faq.dion.vc/api
DION_API_TOKEN=

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin password for the Grafana web UI (http://localhost:3000 in dev).
# Change before production deployment.
GRAFANA_ADMIN_PASSWORD=changeme_grafana

# ── Channel credentials encryption (ADR-0004 §4) ─────────────────────────────
# Fernet key encrypting per-channel SMTP/Telegram/Dion configs at rest.
# MUST be distinct from TOTP_ENC_KEY. notification-svc refuses to start without it.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHANNEL_ENC_KEY=changeme_separate_fernet_key_for_channels
